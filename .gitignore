# Local secrets — never commit
.claude/.upload-secret
.upload-secret
.env
.env.local

# Claude Code permission allowlist — captured Bash patterns can leak
# secrets that were on the command line at approval time.
.claude/settings.local.json

# Build / deploy artefacts
.deploy-payload.json

# Editor / OS junk
.DS_Store
Thumbs.db
*.swp
*.swo

# Skill dependencies — installed locally, not version-controlled
.claude/skills/**/node_modules/
.claude/skills/tpch-doc.zip
.claude/skills/ui-ux-pro-max/scripts/__pycache__/

# Scheduled-task lock
.claude/scheduled_tasks.lock

